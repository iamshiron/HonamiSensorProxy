<?xml version="1.0" encoding="utf-8"?>
<!--
  The bridge targets local-dev backends over plain http:// (e.g. http://192.168.x.x:port).
  Android blocks cleartext by default since API 28, so we opt back in here.
  Production sinks should use HTTPS (BridgeApp.md §12.1/§14); tighten or remove this for release builds.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true"/>
</network-security-config>
